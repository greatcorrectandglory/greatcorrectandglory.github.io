---
import ProductLayout from "../layouts/ProductLayout.astro";

const title = "通用自动化测试平台 | 电子产品研发验证与产线测试软件";
const description = "通用自动化测试平台面向电子产品研发验证与产线测试，统一管理产品配置、硬件资源、测试步骤、判定规则、结果追溯及MES/云端上报，基于配置包、插件化步骤和统一运行时减少重复开发，缩短新产品导入时间，并降低现场交付、维护和质量复盘复杂度，适合多工位测试与MES对接评估。";

const painPoints = [
  "每个新产品都需要复制或修改一套测试程序，重复开发难以避免。",
  "硬件连接、测试流程和判定标准散落在代码中，产品切换依赖软件工程师。",
  "测试结果、异常日志、工位和序列号难以关联，现场复盘成本高。",
  "烧录、功能测试、结果存储和 MES 上报缺少统一流程。",
  "研发验证与产线交付使用不同工具，经验难以沉淀为平台能力。"
];

const outcomes = [
  {
    title: "更快导入新产品",
    text: "通过 Product Bundle 承载产品差异，优先调整配置包、资源绑定和测试计划，而不是复制整套程序。"
  },
  {
    title: "减少重复开发",
    text: "把通用测试动作沉淀为 Step Plugin，把仪器与 DUT 接入沉淀为 Resource Plugin，项目只组合和配置能力。"
  },
  {
    title: "降低现场交付复杂度",
    text: "由 Runtime 统一执行、Validation 统一判定、Listener 统一记录和上报，便于预检、追溯和维护。"
  }
];

const interfaces = [
  ["主测试界面", "展示产品选择、序列号录入、多工位运行状态与 PASS/FAIL 结果。"],
  ["产品配置界面", "展示资源绑定、测试计划、治具参数和监听器配置的公开安全截图。"],
  ["结果与日志界面", "展示步骤结果、异常提示、日志定位与本地追溯信息。"]
];

const flow = [
  "选择产品 / 扫描序列号",
  "加载 Product Bundle",
  "初始化 DUT 与仪器资源",
  "按 test_plan 执行步骤",
  "采集测量值",
  "执行 Validation 判定",
  "保存日志、结果与附件",
  "本地存储或外部系统上报"
];

const capabilities = [
  ["产品配置包", "用 bench.yaml、test_plan.yaml、fixture_settings.yaml、listeners.yaml 组织产品差异。", "/test-platform/docs/#product-bundle"],
  ["测试流程编排", "以测试计划表达步骤、资源绑定、输入参数和规则，不把流程写死在界面里。", "/test-platform/architecture/#runtime-flow"],
  ["硬件资源管理", "统一管理 DUT、仪器、测试板、烧录器和仿真资源的初始化与释放。", "/test-platform/architecture/#resource-lifecycle"],
  ["插件化扩展", "支持测试步骤插件、硬件资源插件和结果监听器插件。", "/test-platform/architecture/#extension-boundary"],
  ["规则判定", "由 Validation 层执行测量值和期望规则的判定，输出可追溯结果。", "/test-platform/architecture/#validation"],
  ["结果追溯与外部集成", "通过日志、SQLite、MQTT 或 Listener 对接外部系统，具体字段按项目评估。", "/test-platform/docs/#operations"]
];

const roles = [
  ["测试员", "选择产品、输入或扫描序列号、启动测试、查看 PASS/FAIL 和异常提示。"],
  ["硬件工程师", "配置仪器、DUT、串口、USB、网络连接和治具参数，验证资源绑定。"],
  ["软件工程师", "开发测试步骤插件、资源插件、监听器插件和外部系统集成。"]
];

const compatibility = [
  ["操作系统", "Windows 支持完整 GUI 与后台运行；Linux 仅作为后台 Python 运行路径；macOS 当前不在范围内。"],
  ["GUI 交付方式", "Windows + PyQt/PySide 桌面应用，面向本地工站使用。"],
  ["后台运行方式", "Python 3.8+ 运行时，按产品配置包加载并执行测试计划。"],
  ["产品配置格式", "YAML Product Bundle：bench、test_plan、fixture_settings、listeners。"],
  ["支持的硬件通信类型", "串口、USB、仿真资源已有抽象；网络与专用设备根据具体硬件项目评估。"],
  ["结果存储方式", "本地日志、SQLite 结果库和 Listener 输出；附件策略按项目评估。"],
  ["外部集成方式", "MQTT、MES 或云端系统通过 Listener/API 对接，字段和认证方式按项目评估。"],
  ["插件类型", "测试步骤插件、硬件资源插件、结果监听器插件。"]
];

const docs = [
  ["快速开始", "/test-platform/docs/#getting-started"],
  ["系统要求", "/test-platform/docs/#getting-started"],
  ["产品配置包说明", "/test-platform/docs/#product-bundle"],
  ["测试运行生命周期", "/test-platform/architecture/#data-flow"],
  ["硬件资源接入", "/test-platform/docs/#extension"],
  ["测试步骤开发", "/test-platform/docs/#extension"],
  ["结果监听与上报", "/test-platform/docs/#operations"],
  ["常见问题", "/test-platform/docs/#faq"],
  ["部署检查表", "/test-platform/docs/#operations"],
  ["版本记录", "/test-platform/changelog/"]
];

const demoSteps = ["加载配置包", "初始化资源", "执行步骤插件", "Validation 判定", "Listener 记录"];
---

<ProductLayout title={title} description={description} canonicalPath="/test-platform/">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">Engineering Preview · 电子产品测试平台</p>
      <h1 id="hero-title">让电子产品测试从定制脚本，升级为可复用的平台能力</h1>
      <p class="hero-lead">
        面向研发验证与产线测试，统一管理产品配置、硬件资源、测试步骤、判定规则、结果追溯及 MES / 云端上报。
      </p>
      <div class="hero-actions">
        <a class="primary-action" href="#interactive-demo">查看交互演示</a>
        <a class="secondary-action" href="/test-platform/architecture/">查看技术架构</a>
      </div>
      <dl class="status-row" aria-label="当前状态">
        <div><dt>当前版本</dt><dd>待确认</dd></div>
        <div><dt>最后更新</dt><dd>2026-06-22</dd></div>
        <div><dt>交付入口</dt><dd>Windows GUI</dd></div>
      </dl>
    </div>
    <div class="demo-shell" id="interactive-demo" aria-label="通用自动化测试平台交互演示">
      <div class="demo-topbar">
        <div class="demo-brand">
          <span class="demo-mark" aria-hidden="true">T</span>
          <strong>TestPlatform Core</strong>
        </div>
        <div class="demo-switch" role="tablist" aria-label="演示模式">
          <button class="active" type="button" data-demo-tab="operator" role="tab" aria-selected="true">运行态</button>
          <button type="button" data-demo-tab="engineer" role="tab" aria-selected="false">配置态</button>
        </div>
      </div>

      <div class="demo-statusbar" aria-label="演示状态">
        <span><i class="status-dot"></i>Runtime Ready</span>
        <span><i class="status-dot"></i>Local DB OK</span>
        <span><i class="status-dot muted"></i>MES 模拟输出</span>
      </div>

      <div class="demo-view active" data-demo-view="operator">
        <div class="demo-layout">
          <aside class="demo-side-panel">
            <p class="demo-label">设备准备就绪</p>
            <label class="demo-field">
              <span>等待扫描序列号</span>
              <input id="demo-sn" type="text" value="SN-DEMO-0422" aria-label="演示序列号" />
            </label>
            <button class="demo-run-button" type="button" data-demo-run>开始测试</button>
            <div class="bundle-card">
              <span>当前 Bundle</span>
              <strong>DEMO_FCT_BUNDLE.yaml</strong>
              <small>公开模拟配置 · 无真实产品信息</small>
            </div>
          </aside>

          <section class="demo-result-card" aria-live="polite">
            <div class="result-orb" data-demo-orb>READY</div>
            <h2 data-demo-result>等待测试开始</h2>
            <p data-demo-desc>点击开始测试，演示 Runtime 如何加载配置、执行步骤、判定并记录结果。</p>
            <div class="demo-progress" aria-label="测试进度">
              <span data-demo-progress></span>
            </div>
            <ol class="demo-step-list">
              {demoSteps.map((step) => <li>{step}</li>)}
            </ol>
          </section>
        </div>

        <div class="trace-panel">
          <div class="trace-head">
            <span>Trace Log</span>
            <strong>Auto-scroll</strong>
          </div>
          <div class="trace-body" data-demo-log>
            <p>[SYSTEM] Runtime ready. Waiting for product selection...</p>
            <p>[CONFIG] Demo bundle loaded in preview mode.</p>
            <p>[SAFETY] Public demo uses synthetic SN and anonymous resources.</p>
          </div>
        </div>
      </div>

      <div class="demo-view" data-demo-view="engineer">
        <div class="engineer-grid">
          <aside class="bundle-list">
            <p class="demo-label">Product Bundle</p>
            <button class="active" type="button">bench.yaml</button>
            <button type="button">test_plan.yaml</button>
            <button type="button">fixture_settings.yaml</button>
            <button type="button">listeners.yaml</button>
          </aside>
          <section class="config-editor">
            <div class="editor-chrome">
              <span></span><span></span><span></span>
              <strong>test_plan.yaml · Preview</strong>
            </div>
            <pre><code>profile: demo_fct
steps:
  - id: voltage_check
    plugin: measurement.step
    resource: dmm_1
    validation:
      min: 4.8
      max: 5.2
listeners:
  - local_result_db
  - external_report_adapter</code></pre>
          </section>
          <aside class="plugin-map">
            <p class="demo-label">Plugin Boundary</p>
            <div><strong>Step Plugin</strong><span>测量 / 烧录 / 通信</span></div>
            <div><strong>Resource Plugin</strong><span>DUT / 仪器 / 仿真</span></div>
            <div><strong>Listener Plugin</strong><span>SQLite / MQTT / 外部系统</span></div>
          </aside>
        </div>
      </div>

      <p class="demo-note">交互演示为公开脱敏模拟，不连接真实设备、客户系统或内部协议。</p>
    </div>
  </section>

  <section class="section deck-section" aria-labelledby="workflow-title">
    <div class="section-head">
      <div>
        <p class="section-kicker">用户 30 秒理解</p>
        <h2 id="workflow-title">一次测试如何完成</h2>
      </div>
      <p>页面先让客户理解从“选择产品”到“结果追溯”的闭环，再进入架构、配置和扩展细节。</p>
    </div>
    <ol class="deck-flow">
      {flow.slice(0, 6).map((item) => <li><strong>{item.split(" / ")[0]}</strong><span>{item.includes(" / ") ? item.split(" / ")[1] : "平台自动处理"}</span></li>)}
    </ol>
    <div class="grid three intro-cards">
      <article class="card"><span class="icon">1</span><h3>定义产品</h3><p>工程师维护资源、步骤、参数和判定规则，形成可复用的产品配置包。</p></article>
      <article class="card"><span class="icon">2</span><h3>执行测试</h3><p>操作员选择产品、扫码并启动测试，Runtime 按配置执行完整流程。</p></article>
      <article class="card"><span class="icon">3</span><h3>记录结果</h3><p>步骤结果、测量值、日志和最终判定进入本地记录或监听器输出。</p></article>
    </div>
  </section>

  <section class="section tint operator-section" aria-labelledby="operator-title">
    <div class="section-head">
      <div>
        <p class="section-kicker">Operator Mode</p>
        <h2 id="operator-title">操作员视角：少判断，直接测试</h2>
      </div>
      <p>产线界面只暴露必要动作和状态，不让操作员处理复杂配置。</p>
    </div>
    <div class="grid two">
      <article class="card runtime-card">
        <div class="statusline"><h3>当前运行任务</h3><span class="badge blue">READY</span></div>
        <div class="inputbox">SN-DEMO-0422</div>
        <div class="task-grid">
          <div><small>产品</small><strong>Demo FCT</strong></div>
          <div><small>工位</small><strong>Station 01</strong></div>
          <div><small>Bundle</small><strong>Preview</strong></div>
          <div><small>状态</small><strong>READY</strong></div>
        </div>
        <button class="demo-run-button inline" type="button" data-demo-run-secondary>演示一次测试</button>
      </article>
      <article class="card running-card">
        <div class="statusline"><h3>执行状态</h3><span class="badge green">TRACEABLE</span></div>
        <div class="progress large"><div></div></div>
        <div class="steps">
          <div class="step"><b>初始化测试环境</b><span class="ok">OK</span></div>
          <div class="step"><b>连接 DUT</b><span class="ok">OK</span></div>
          <div class="step"><b>读取固件版本</b><span class="ok">OK</span></div>
          <div class="step"><b>静态电流检查</b><span class="run">RUNNING</span></div>
          <div class="step"><b>通信功能检查</b><span class="wait">WAIT</span></div>
        </div>
      </article>
    </div>
  </section>

  <section class="section result-section" aria-labelledby="result-title">
    <div class="section-head">
      <div>
        <p class="section-kicker">Result States</p>
        <h2 id="result-title">结果必须直观：PASS 与 FAIL 都要能演示</h2>
      </div>
      <p>客户要一眼看懂结果、失败位置、失败原因，以及数据是否已经保存。</p>
    </div>
    <div class="grid two">
      <article class="result-state pass-state">
        <strong>PASS</strong>
        <h3>测试通过</h3>
        <p>全部步骤完成，测量值位于限制范围内，结果已写入本地记录并进入监听器流程。</p>
        <span class="badge green">SN-DEMO-0422 · Completed</span>
      </article>
      <article class="result-state fail-state">
        <strong>FAIL</strong>
        <h3>测试失败</h3>
        <p>失败步骤：静态电流检查；测量值超出上限。测试终止并记录失败详情。</p>
        <span class="badge red">Current_Check · Upper Limit</span>
      </article>
    </div>
  </section>

  <section class="section tint engineer-section" aria-labelledby="engineer-title">
    <div class="section-head">
      <div>
        <p class="section-kicker">Engineer Mode</p>
        <h2 id="engineer-title">工程师视角：产品配置包驱动测试行为</h2>
      </div>
      <p>工程师维护资源、步骤、治具变量和监听策略，而不是为每个产品复制一套程序。</p>
    </div>
    <div class="tabs">
      <span class="tab active">bench.yaml</span>
      <span class="tab">test_plan.yaml</span>
      <span class="tab">fixture_settings.yaml</span>
      <span class="tab">listeners.yaml</span>
    </div>
    <div class="mock-grid">
      <aside class="sidebar">
        <h3>Product Bundle</h3>
        <span class="side-item active">DEMO_FCT</span>
        <span class="side-item">bench.yaml</span>
        <span class="side-item">test_plan.yaml</span>
        <span class="side-item">fixture_settings.yaml</span>
        <span class="side-item">listeners.yaml</span>
        <strong class="badge green">Config Validated</strong>
      </aside>
      <section class="editor">
        <div class="editor-chrome"><span></span><span></span><span></span><strong>test_plan.yaml</strong></div>
        <pre><code>profile: demo_fct
resource_bindings:
  dut: demo_dut
  power: simulated_power

steps:
  - name: Voltage_Check
    plugin: dmm_measure
    limits:
      lower: 4.8
      upper: 5.2
  - name: Current_Check
    plugin: power_current
    limits:
      upper: 150mA</code></pre>
      </section>
    </div>
  </section>

  <section class="section dark" aria-labelledby="flow-title">
    <p class="section-kicker">测试执行流程</p>
    <h2 id="flow-title">客户先理解平台如何工作，再深入查看架构细节</h2>
    <ol class="flow-list">
      {flow.map((item) => <li>{item}</li>)}
    </ol>
  </section>

  <section class="section" aria-labelledby="scenario-title">
    <p class="section-kicker">典型应用场景</p>
    <h2 id="scenario-title">从研发验证到产线测试，优先覆盖可确认的通用场景</h2>
    <div class="scenario-preview">
      <a class="scenario-row" href="/test-platform/scenarios/"><strong>研发阶段功能验证</strong><span>样机测试、参数验证、日志留存</span></a>
      <a class="scenario-row" href="/test-platform/scenarios/"><strong>电子产品产线测试</strong><span>工站执行、资源绑定、结果追溯</span></a>
      <a class="scenario-row" href="/test-platform/scenarios/"><strong>MES 或云端系统对接</strong><span>通过 Listener/API 按项目评估接入</span></a>
    </div>
  </section>

  <section class="section tint" id="capabilities" aria-labelledby="capability-title">
    <p class="section-kicker">核心能力清单</p>
    <h2 id="capability-title">围绕通用测试平台、自动化测试平台和产线测试软件的六类能力</h2>
    <div class="grid three">
      {capabilities.map(([name, text, href]) => (
        <article class="card capability-card">
          <h3>{name}</h3>
          <p>{text}</p>
          <a href={href}>查看证据入口</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="roles-title">
    <p class="section-kicker">三类用户入口</p>
    <h2 id="roles-title">不同角色使用同一平台，但接触不同操作深度</h2>
    <div class="grid three">
      {roles.map(([role, text]) => (
        <article class="card role-card">
          <p class="role-label">{role}</p>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="compat-title">
    <p class="section-kicker">兼容性与交付边界</p>
    <h2 id="compat-title">公开页面只展示已确认范围，未确认能力按项目评估</h2>
    <div class="matrix" role="table" aria-label="兼容性矩阵">
      {compatibility.map(([name, value]) => (
        <div class="matrix-row" role="row">
          <strong role="cell">{name}</strong>
          <span role="cell">{value}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section tint" aria-labelledby="docs-title">
    <p class="section-kicker">文档和技术资源</p>
    <h2 id="docs-title">公开文档先给评估入口，细节内容经过脱敏后再逐步补充</h2>
    <div class="doc-links">
      {docs.map(([label, href]) => <a href={href}>{label}</a>)}
    </div>
  </section>

  <section class="section faq" aria-labelledby="faq-title">
    <p class="section-kicker">FAQ</p>
    <h2 id="faq-title">常见问题</h2>
    <details>
      <summary>这是开源框架还是企业测试软件？</summary>
      <p>这是面向企业内部研发验证与产线测试的通用自动化测试平台。官网只公开产品能力和评估信息，不公开私有源码或客户资料。</p>
    </details>
    <details>
      <summary>是否承诺零代码或完全无开发接入？</summary>
      <p>不做此类承诺。平台优先通过配置包复用能力；当硬件、步骤或外部系统存在差异时，仍需要插件或集成开发。</p>
    </details>
    <details>
      <summary>是否已经内置所有 MES 或云平台协议？</summary>
      <p>不这样表述。平台提供结果监听和外部集成边界，具体系统字段、认证方式和网络环境需要按项目确认。</p>
    </details>
  </section>

  <section class="section contact" id="contact" aria-labelledby="contact-title">
    <p class="section-kicker">联系/演示申请</p>
    <h2 id="contact-title">想评估新产品导入、多工位执行或结果追溯是否适合平台化？</h2>
    <p>请通过 GitHub 主页联系作者，说明测试场景、硬件资源类型、结果上报方式和希望查看的演示重点。请勿在公开渠道提交客户名称、真实产品型号、账号、密钥或协议字段。</p>
    <div class="hero-actions center">
      <a class="primary-action" href="https://github.com/greatcorrectandglory" rel="noreferrer">联系作者</a>
      <a class="secondary-action" href="/test-platform/docs/">阅读文档</a>
      <a class="secondary-action" href="/test-platform/architecture/">查看架构</a>
    </div>
  </section>

  <script>
    const tabButtons = document.querySelectorAll("[data-demo-tab]");
    const demoViews = document.querySelectorAll("[data-demo-view]");
    const runButton = document.querySelector("[data-demo-run]");
    const secondaryRunButton = document.querySelector("[data-demo-run-secondary]");
    const resultText = document.querySelector("[data-demo-result]");
    const resultDesc = document.querySelector("[data-demo-desc]");
    const resultOrb = document.querySelector("[data-demo-orb]");
    const progress = document.querySelector("[data-demo-progress]");
    const log = document.querySelector("[data-demo-log]");
    const snInput = document.querySelector("#demo-sn");

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const mode = button.dataset.demoTab;
        tabButtons.forEach((item) => {
          const selected = item === button;
          item.classList.toggle("active", selected);
          item.setAttribute("aria-selected", String(selected));
        });
        demoViews.forEach((view) => view.classList.toggle("active", view.dataset.demoView === mode));
      });
    });

    const addDemoLog = (message) => {
      if (!log) return;
      const line = document.createElement("p");
      line.textContent = message;
      log.appendChild(line);
      log.scrollTop = log.scrollHeight;
    };

    const runDemo = () => {
      const sn = snInput?.value || "SN-DEMO";
      const steps = [
        "[SCAN] Accepted synthetic SN " + sn,
        "[CONFIG] Product Bundle validation passed.",
        "[RESOURCE] Demo DUT and instrument resources initialized.",
        "[STEP] measurement.step returned value within limits.",
        "[VALIDATION] Rule evaluation completed: PASS.",
        "[LISTENER] Local result saved; external report queued in demo mode."
      ];

      runButton.setAttribute("disabled", "true");
      resultOrb.textContent = "RUN";
      resultOrb.className = "result-orb running";
      resultText.textContent = "测试执行中";
      resultDesc.textContent = "Runtime 正在按测试计划执行步骤，并把结果交给 Validation 与 Listener。";
      progress.style.width = "8%";
      addDemoLog("[SYSTEM] Test sequence started.");

      steps.forEach((step, index) => {
        window.setTimeout(() => {
          addDemoLog(step);
          progress.style.width = `${Math.round(((index + 1) / steps.length) * 100)}%`;
          if (index === steps.length - 1) {
            resultOrb.textContent = "PASS";
            resultOrb.className = "result-orb pass";
            resultText.textContent = "PASS";
            resultDesc.textContent = "模拟测试通过：结果已写入本地记录，外部系统输出保持项目级评估。";
            runButton.removeAttribute("disabled");
          }
        }, 460 * (index + 1));
      });
    };

    runButton?.addEventListener("click", runDemo);
    secondaryRunButton?.addEventListener("click", () => {
      document.querySelector("#interactive-demo")?.scrollIntoView({ behavior: "smooth", block: "center" });
      runDemo();
    });
  </script>
</ProductLayout>
